# Supabase — fill in after creating Supabase project at supabase.com (region: ap-northeast-1)
# Get these from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service-role key — MIGRATION ONLY. Never used in Server Actions code (ADR-005).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App-writer connection string — Server Actions use this. Created in migration 009.
# Format: postgresql://app_writer:<PASSWORD>@<host>:5432/postgres
SUPABASE_APP_DB_URL=postgresql://app_writer:CHANGEME@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# Health endpoint token — Sunday ping bot uses this in X-Health-Token header
HEALTH_PING_TOKEN=generate-a-random-32-char-token

# Resend (Email alerts; PIPA consent export emails)
RESEND_API_KEY=re_...

# Axiom (log aggregation, 90-day retention; supplements Vercel/Supabase 1-7d retention)
AXIOM_TOKEN=xaat-...
AXIOM_DATASET=moneymanager-prod
