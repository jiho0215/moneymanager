{
  "name": "moneybean",
  "version": "0.1.0",
  "private": true,
  "description": "Money Bean — Family web app for kids to experience compound interest",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run lib/",
    "test:watch": "vitest lib/",
    "test:coverage": "vitest run lib/ --coverage",
    "test:integration": "vitest run tests/integration --pool=forks --poolOptions.forks.singleFork=true --no-file-parallelism",
    "test:e2e": "playwright test",
    "db:types": "supabase gen types typescript --local > lib/db/types.ts",
    "db:migrate:local": "supabase db reset",
    "db:migrate:test-reversibility": "node scripts/test-migration-reversibility.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "0.5.2",
    "@supabase/supabase-js": "2.46.1",
    "next": "14.2.18",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.17.6",
    "@types/pg": "^8.20.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.13.0",
    "@typescript-eslint/parser": "8.13.0",
    "@vitest/coverage-v8": "2.1.4",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.18",
    "eslint-plugin-no-restricted-imports": "0.0.0",
    "fast-check": "3.23.1",
    "pg": "^8.20.0",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
