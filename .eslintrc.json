{
  "extends": ["next/core-web-vitals", "plugin:@typescript-eslint/recommended"],
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "rules": {
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "@typescript-eslint/consistent-type-imports": "error"
  },
  "overrides": [
    {
      "files": ["lib/domain/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@supabase/*", "@/lib/db/*", "next/*", "react", "react-dom"],
                "message": "ADR-003: lib/domain/ must be IO-free. See docs/adr/ADR-003-domain-purity-with-typed-boundary.md"
              },
              {
                "group": ["fs", "path", "crypto"],
                "message": "ADR-003: lib/domain/ must not access filesystem or crypto. Inject random/seed via function arguments."
              }
            ]
          }
        ],
        "no-restricted-globals": [
          "error",
          { "name": "Date", "message": "ADR-003: lib/domain/ must not call Date directly. Inject time as argument." }
        ]
      }
    },
    {
      "files": ["app/**/*.ts", "app/**/*.tsx", "lib/**/*.ts"],
      "excludedFiles": ["lib/db/**", "supabase/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["**/SUPABASE_SERVICE_ROLE_KEY*"],
                "message": "ADR-005: service_role key is migration-only. Use SUPABASE_APP_DB_URL (app_writer credentials) for Server Actions."
              }
            ]
          }
        ]
      }
    }
  ]
}
